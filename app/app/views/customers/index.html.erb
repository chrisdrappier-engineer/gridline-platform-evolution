<% content_for :title, "Customers" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Operations</p>
    <h1>Customers</h1>
  </div>
  <%= link_to "View Requests", service_requests_path, class: "secondary-button" %>
</section>

<% if @customers.any? %>
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Customer</th>
          <th>Status</th>
          <th>Industry</th>
          <th>Created By</th>
        </tr>
      </thead>
      <tbody>
        <% @customers.each do |customer| %>
          <tr>
            <td><%= link_to customer.name, customer_path(customer), class: "table-link" %></td>
            <td><%= customer.account_status.humanize %></td>
            <td><%= customer.industry.humanize %></td>
            <td><%= customer.created_by.name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="empty-state">
    <h2>No visible customers</h2>
    <p>Your current role assignments do not expose any customer records.</p>
  </div>
<% end %>
