<% content_for :title, "Customers" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Operations</p>
    <h1>Customers</h1>
  </div>
  <div class="action-row">
    <%= render "shared/actions", actions: @page_actions %>
  </div>
</section>

<%= turbo_frame_tag @customers_table.frame_id, target: "_top", data: { turbo_action: "advance" } do %>
  <%= render "shared/data_tables/controls", table: @customers_table, search_placeholder: "Search customers, industries, creators" %>

  <%= render_collection_state(
        @customers,
        present_partial: "customers/table",
        empty_title: @customers_table.empty_title,
        empty_message: @customers_table.empty_message,
        locals: { customers: @customers, customers_table: @customers_table }
      ) %>

  <%= render "shared/data_tables/pagination", table: @customers_table %>
<% end %>
