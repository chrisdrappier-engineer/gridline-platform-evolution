<% content_for :title, @customer.name %>

<section class="page-header">
  <div>
    <p class="eyebrow">Customer</p>
    <h1><%= @customer.name %></h1>
  </div>
  <div class="action-row">
    <%= render "shared/actions", actions: @page_actions %>
  </div>
</section>

<section class="detail-grid">
  <article class="detail-panel">
    <h2>Account</h2>
    <dl class="detail-list">
      <dt>Status</dt>
      <dd><%= @customer.account_status.humanize %></dd>
      <dt>Industry</dt>
      <dd><%= @customer.industry %></dd>
      <dt>Quote Approval Threshold</dt>
      <dd><%= format_money_cents(@customer.quote_approval_threshold_cents) %></dd>
      <dt>Created By</dt>
      <dd><%= @customer.created_by.name %></dd>
    </dl>
  </article>

  <article class="detail-panel">
    <div class="section-header">
      <h2>Sites</h2>
      <%= render "shared/actions", actions: @customer_site_actions %>
    </div>
    <ul class="link-list">
      <% @customer_sites.each do |site| %>
        <li><%= link_to site.name, customer_site_path(site) %></li>
      <% end %>
    </ul>
  </article>
</section>

<section class="section-block">
  <div class="section-header">
    <h2>Service Requests</h2>
    <%= render "shared/actions", actions: @service_request_actions %>
  </div>

  <%= render "service_requests/table", service_requests: @service_requests %>
</section>
