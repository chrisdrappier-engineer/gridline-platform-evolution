<% content_for :title, "Service Providers" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Operations</p>
    <h1>Service Providers</h1>
  </div>
  <div class="action-row">
    <%= render "shared/actions", actions: @page_actions %>
  </div>
</section>

<%= turbo_frame_tag @service_providers_table.frame_id, target: "_top", data: { turbo_action: "advance" } do %>
  <%= render "shared/data_tables/controls", table: @service_providers_table, search_placeholder: "Search providers, types, creators" %>

  <%= render_collection_state(
        @service_providers,
        present_partial: "service_providers/table",
        empty_title: @service_providers_table.empty_title,
        empty_message: @service_providers_table.empty_message,
        locals: {
          service_providers: @service_providers,
          service_providers_table: @service_providers_table
        }
      ) %>

  <%= render "shared/data_tables/pagination", table: @service_providers_table %>
<% end %>
