<% content_for :title, @service_provider.name %>

<section class="page-header">
  <div>
    <p class="eyebrow">Service Provider</p>
    <h1><%= @service_provider.name %></h1>
  </div>
  <div class="action-row">
    <%= link_to "Back to Requests", service_requests_path, class: "secondary-button" %>
    <% if can?("service_providers", "update", @service_provider) %>
      <%= link_to "Edit Provider", edit_service_provider_path(@service_provider), class: "primary-button" %>
    <% end %>
  </div>
</section>

<section class="detail-grid">
  <article class="detail-panel">
    <h2>Provider Details</h2>
    <dl class="detail-list">
      <dt>Type</dt>
      <dd><%= @service_provider.provider_type.humanize %></dd>
      <dt>Status</dt>
      <dd><%= @service_provider.status.humanize %></dd>
      <dt>Created By</dt>
      <dd><%= @service_provider.created_by.name %></dd>
    </dl>
  </article>

  <article class="metric-card">
    <span>Related Requests</span>
    <strong><%= @service_requests.count %></strong>
  </article>

  <article class="metric-card">
    <span>Open Requests</span>
    <strong><%= @performance_summary.open_count %></strong>
  </article>

  <article class="metric-card">
    <span>Resolution Rate</span>
    <strong>
      <% if @performance_summary.resolution_percentage %>
        <%= @performance_summary.resolution_percentage %>%
      <% else %>
        Not enough data
      <% end %>
    </strong>
  </article>

  <article class="metric-card">
    <span>Avg Response Time</span>
    <strong><%= format_duration_seconds(@performance_summary.average_provider_response_seconds) %></strong>
  </article>

  <article class="metric-card">
    <span>Avg Completion Time</span>
    <strong><%= format_duration_seconds(@performance_summary.average_provider_completion_seconds) %></strong>
  </article>

  <article class="metric-card">
    <span>Avg Resolution Time</span>
    <strong><%= format_duration_seconds(@performance_summary.average_resolution_seconds) %></strong>
  </article>
</section>

<section class="section-block">
  <div class="section-header">
    <h2>Service Requests</h2>
    <% if permitted?("service_requests", "create") %>
      <%= link_to "New Request", new_service_request_path, class: "secondary-button" %>
    <% end %>
  </div>

  <%= render "service_requests/table", service_requests: @service_requests %>
</section>
