<% content_for :title, "Role Assignments" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Administration</p>
    <h1>Role Assignments</h1>
  </div>
  <%= link_to "Permission Matrix", admin_role_permissions_path, class: "secondary-button" %>
</section>

<%= turbo_frame_tag @role_assignments_table.frame_id, target: "_top", data: { turbo_action: "advance" } do %>
  <%= render "shared/data_tables/controls",
             table: @role_assignments_table,
             context: { roles: @roles },
             search_placeholder: "Search users, roles, scopes" %>

  <%= render_collection_state(
        @role_assignments,
        present_partial: "admin/role_assignments/table",
        empty_title: @role_assignments_table.empty_title,
        empty_message: @role_assignments_table.empty_message,
        locals: {
          role_assignments: @role_assignments,
          role_assignments_table: @role_assignments_table
        }
      ) %>

  <%= render "shared/data_tables/pagination", table: @role_assignments_table %>
<% end %>
