<% content_for :title, "Admin Dashboard" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Admin</p>
    <h1>Admin Dashboard</h1>
  </div>
  <%= link_to "View Requests", service_requests_path, class: "primary-button" %>
</section>

<section class="metric-grid" aria-label="Admin summary">
  <article class="metric-card">
    <span>Roles</span>
    <strong><%= @roles.count %></strong>
  </article>
  <article class="metric-card">
    <span>Permissions</span>
    <strong><%= @permissions.count %></strong>
  </article>
  <article class="metric-card">
    <span>Assignments</span>
    <strong><%= @role_assignments.count %></strong>
  </article>
</section>

<section class="section-block">
  <div class="section-header">
    <h2>Role Permission Matrix</h2>
  </div>

  <div class="table-wrap">
    <table class="data-table permission-matrix">
      <thead>
        <tr>
          <th>Permission</th>
          <% @roles.each do |role| %>
            <th><%= role.name %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @permissions.each do |permission| %>
          <tr>
            <th scope="row">
              <span class="table-link"><%= permission.name %></span>
              <span class="muted-link"><%= permission.resource %> / <%= permission.action %></span>
            </th>
            <% @roles.each do |role| %>
              <td>
                <% if role.permissions.any? { |role_permission| role_permission.id == permission.id } %>
                  <span class="matrix-allowed" aria-label="<%= role.name %> can <%= permission.action %> <%= permission.resource %>">Allowed</span>
                <% else %>
                  <span class="matrix-denied" aria-label="<%= role.name %> cannot <%= permission.action %> <%= permission.resource %>">Not allowed</span>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="detail-grid">
  <article class="detail-panel">
    <h2>Roles</h2>
    <ul class="link-list">
      <% @roles.each do |role| %>
        <li><%= role.name %></li>
      <% end %>
    </ul>
  </article>

  <article class="detail-panel">
    <h2>Recent Role Assignments</h2>
    <ul class="link-list">
      <% @role_assignments.limit(8).each do |assignment| %>
        <li>
          <%= assignment.user.name %>:
          <%= assignment.role.name %>
          <% if assignment.resource %>
            on <%= assignment.resource_type %>
          <% else %>
            globally
          <% end %>
        </li>
      <% end %>
    </ul>
  </article>
</section>

<%= render "recent_requests", service_requests: @recent_requests, title: "Recent Requests" %>
