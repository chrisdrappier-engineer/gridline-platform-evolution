<% content_for :title, "Dashboard" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Today</p>
    <h1>Dispatcher Dashboard</h1>
  </div>
  <%= link_to "Create Request", new_service_request_path, class: "primary-button" %>
</section>

<section class="metric-grid" aria-label="Service request summary">
  <article class="metric-card">
    <span>Open Requests</span>
    <strong><%= @open_requests.count %></strong>
  </article>
  <article class="metric-card">
    <span>New Queue</span>
    <strong><%= @new_requests.count %></strong>
  </article>
  <article class="metric-card urgent">
    <span>Urgent Active</span>
    <strong><%= @urgent_requests.count %></strong>
  </article>
</section>

<section class="section-block">
  <div class="section-header">
    <h2>Recent Requests</h2>
    <%= link_to "View all", service_requests_path %>
  </div>

  <%= render "service_requests/table", service_requests: @recent_requests %>
</section>
