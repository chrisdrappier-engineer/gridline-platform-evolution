<% content_for :title, "Sites" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Operations</p>
    <h1>Sites</h1>
  </div>
  <div class="action-row">
    <%= render "shared/actions", actions: @page_actions %>
  </div>
</section>

<%= turbo_frame_tag @customer_sites_table.frame_id, target: "_top", data: { turbo_action: "advance" } do %>
  <%= render "shared/data_tables/controls", table: @customer_sites_table, search_placeholder: "Search sites, customers, locations" %>

  <%= render_collection_state(
        @customer_sites,
        present_partial: "customer_sites/table",
        empty_title: @customer_sites_table.empty_title,
        empty_message: @customer_sites_table.empty_message,
        locals: {
          customer_sites: @customer_sites,
          customer_sites_table: @customer_sites_table,
          site_row_actions: @site_row_actions
        }
      ) %>

  <%= render "shared/data_tables/pagination", table: @customer_sites_table %>
<% end %>
