<% content_for :title, "Sites" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Operations</p>
    <h1>Sites</h1>
  </div>
  <div class="action-row">
    <%= link_to "View Requests", service_requests_path, class: "secondary-button" %>
    <% if permitted?("customer_sites", "create") %>
      <%= link_to "New Site", new_customer_site_path, class: "primary-button" %>
    <% end %>
  </div>
</section>

<%= turbo_frame_tag @customer_sites_table.frame_id, target: "_top", data: { turbo_action: "advance" } do %>
  <%= render "shared/data_tables/controls", table: @customer_sites_table, search_placeholder: "Search sites, customers, locations" %>

  <% if @customer_sites.any? %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <% @customer_sites_table.columns.each do |column| %>
              <th><%= data_table_sort_link(@customer_sites_table, column) %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @customer_sites.each do |site| %>
            <tr>
              <td><%= link_to site.name, customer_site_path(site), class: "table-link" %></td>
              <td><%= link_to site.customer.name, customer_path(site.customer), class: "table-link" %></td>
              <td><%= site.site_status.humanize %></td>
              <td><%= site.city %>, <%= site.state %></td>
              <td>
                <% if can?("service_requests", "create", site) %>
                  <%= link_to "Create Request", new_service_request_path(customer_site_id: site.id), class: "table-link" %>
                <% end %>
                <% if can?("customer_sites", "update", site) %>
                  <%= link_to "Edit", edit_customer_site_path(site), class: "table-link" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state">
      <h2><%= @customer_sites_table.empty_title %></h2>
      <p><%= @customer_sites_table.empty_message %></p>
    </div>
  <% end %>

  <%= render "shared/data_tables/pagination", table: @customer_sites_table %>
<% end %>
