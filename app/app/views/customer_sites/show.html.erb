<% content_for :title, @customer_site.name %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= @customer_site.customer.name %></p>
    <h1><%= @customer_site.name %></h1>
  </div>
  <div class="action-row">
    <%= render "shared/actions", actions: @page_actions %>
  </div>
</section>

<section class="detail-grid">
  <article class="detail-panel">
    <h2>Site Details</h2>
    <dl class="detail-list">
      <dt>Status</dt>
      <dd><%= @customer_site.site_status.humanize %></dd>
      <dt>Address</dt>
      <dd><%= customer_site_address(@customer_site) %></dd>
      <dt>Created By</dt>
      <dd><%= @customer_site.created_by.name %></dd>
      <dt>Facility Managers</dt>
      <dd><%= facility_manager_names(@customer_site) %></dd>
    </dl>
  </article>

  <article class="detail-panel">
    <h2>Customer</h2>
    <dl class="detail-list">
      <dt>Name</dt>
      <dd><%= @customer_site.customer.name %></dd>
      <dt>Industry</dt>
      <dd><%= @customer_site.customer.industry %></dd>
      <dt>Status</dt>
      <dd><%= @customer_site.customer.account_status.humanize %></dd>
    </dl>
  </article>
</section>

<section class="section-block">
  <div class="section-header">
    <h2>Service Requests</h2>
    <%= render "shared/actions", actions: @service_request_actions %>
  </div>

  <%= render "service_requests/table", service_requests: @service_requests %>
</section>
