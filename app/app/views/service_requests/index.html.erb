<% content_for :title, "Service Requests" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Operations Queue</p>
    <h1>Service Requests</h1>
  </div>
  <%= link_to "New Request", new_service_request_path, class: "primary-button" %>
</section>

<%= turbo_frame_tag @service_requests_table.frame_id, target: "_top", data: { turbo_action: "advance" } do %>
  <%= render "shared/data_tables/controls",
             table: @service_requests_table,
             context: { filter_sites: @filter_sites, filter_dispatchers: @filter_dispatchers },
             search_placeholder: "Search requests, sites, customers, providers" %>

  <%= render "table", service_requests: @service_requests, table: @service_requests_table %>
  <%= render "shared/data_tables/pagination", table: @service_requests_table %>
<% end %>
