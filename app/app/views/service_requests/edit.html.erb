<% content_for :title, "Edit #{@service_request.title}" %>

<section class="page-header">
  <div>
    <p class="eyebrow">Service Request</p>
    <h1>Edit <%= @service_request.title %></h1>
  </div>
  <%= link_to "Back to Request", service_request_path(@service_request), class: "secondary-button" %>
</section>

<%= form_with model: @service_request, class: "form-panel wide-form" do |form| %>
  <% if @service_request.errors.any? %>
    <div class="error-summary">
      <h2><%= pluralize(@service_request.errors.count, "error") %> prevented this request from being saved</h2>
      <ul>
        <% @service_request.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title %>
    <%= form.text_field :title, required: true %>
  </div>

  <div class="field">
    <%= form.label :status %>
    <%= form.select :status, ServiceRequest::STATUSES.map { |status| [status.humanize, status] }, {}, required: true %>
  </div>

  <div class="field">
    <%= form.label :priority %>
    <%= form.select :priority, ServiceRequest::PRIORITIES.map { |priority| [priority.humanize, priority] }, {}, required: true %>
  </div>

  <div class="field">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 6 %>
  </div>

  <div class="form-actions">
    <%= form.submit "Update Request", class: "primary-button" %>
  </div>
<% end %>
