<% page = @service_request_page %>
<% content_for :title, page.title %>

<section class="page-header">
  <div>
    <p class="eyebrow"><%= page.eyebrow %></p>
    <h1><%= page.title %></h1>
  </div>
  <div class="action-row">
    <%= render "shared/actions", actions: page.header_actions %>
  </div>
</section>

<section class="detail-grid">
  <article class="detail-panel">
    <h2>Request</h2>
    <%= render "shared/detail_list", rows: page.request_rows %>
  </article>

  <article class="detail-panel">
    <h2>Site</h2>
    <%= render "shared/detail_list", rows: page.site_rows %>
  </article>
</section>

<%= render "service_requests/metric_cards", metrics: page.metrics %>

<section class="section-block">
  <h2>Description</h2>
  <div class="request-description"><%= simple_format(page.description) %></div>
</section>

<% page.section_partials.each do |section_partial| %>
  <%= render section_partial, page: page %>
<% end %>
