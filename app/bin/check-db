#!/usr/bin/env ruby
# frozen_string_literal: true

require "pg"

connection = nil

begin
  connection = PG.connect(
    host: ENV.fetch("DATABASE_HOST"),
    port: ENV.fetch("DATABASE_PORT"),
    dbname: ENV.fetch("DATABASE_NAME"),
    user: ENV.fetch("DATABASE_USERNAME"),
    password: ENV.fetch("DATABASE_PASSWORD")
  )

  result = connection.exec("select current_database(), current_user")
  row = result.first

  puts "Connected to Postgres database #{row["current_database"]} as #{row["current_user"]}"
ensure
  connection&.close
end
