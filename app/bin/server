#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "pg"
require "socket"

def database_status
  connection = PG.connect(
    host: ENV.fetch("DATABASE_HOST"),
    port: ENV.fetch("DATABASE_PORT"),
    dbname: ENV.fetch("DATABASE_NAME"),
    user: ENV.fetch("DATABASE_USERNAME"),
    password: ENV.fetch("DATABASE_PASSWORD")
  )
  connection.exec("select 1")
  "reachable"
ensure
  connection&.close
end

port = Integer(ENV.fetch("APP_PORT", 3000))
puts "Starting Gridline placeholder app on port #{port}"
server = TCPServer.new("0.0.0.0", port)

loop do
  client = server.accept

  begin
    request_line = client.gets.to_s
    path = request_line.split[1] || "/"

    while (line = client.gets)
      break if line == "\r\n"
    end

    if path == "/health"
      body = { status: "ok", database: database_status }.to_json
      client.write "HTTP/1.1 200 OK\r\n"
      client.write "content-type: application/json\r\n"
      client.write "content-length: #{body.bytesize}\r\n"
      client.write "connection: close\r\n"
      client.write "\r\n"
      client.write body
    else
      body = "Gridline baseline container is running\n"
      client.write "HTTP/1.1 200 OK\r\n"
      client.write "content-type: text/plain\r\n"
      client.write "content-length: #{body.bytesize}\r\n"
      client.write "connection: close\r\n"
      client.write "\r\n"
      client.write body
    end
  ensure
    client.close
  end
end
