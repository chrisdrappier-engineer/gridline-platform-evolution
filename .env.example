# Local Docker Compose defaults for the baseline simulation.
#
# Copy this file to .env only when local overrides are needed. These values are
# safe development defaults and are not production secrets.
APP_ENV=development
APP_PORT=3000

POSTGRES_DB=gridline_development
POSTGRES_USER=gridline
POSTGRES_PASSWORD=gridline

DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=gridline_development
DATABASE_USERNAME=gridline
DATABASE_PASSWORD=gridline
