<h3>Record Actual Cost</h3>
<%= form_with model: [page.service_request, page.cost_form], class: "form-panel embedded-form" do |form| %>
  <div class="field">
    <%= form.label :category %>
    <%= form.select :category, page.cost_categories, { prompt: "Select a category" }, required: true %>
  </div>
  <div class="field">
    <%= form.label :amount_dollars, "Amount" %>
    <%= form.number_field :amount_dollars, step: "0.01", min: "0.01", required: true %>
  </div>
  <div class="field">
    <%= form.label :incurred_on, "Incurred On" %>
    <%= form.date_field :incurred_on, required: true %>
  </div>
  <div class="field">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 3 %>
  </div>
  <div class="form-actions">
    <%= form.submit "Record Cost", class: "primary-button" %>
  </div>
<% end %>
