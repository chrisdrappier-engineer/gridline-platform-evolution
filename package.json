{
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint:css": "node_modules/.bin/node node_modules/stylelint/bin/stylelint.mjs \"app/app/assets/stylesheets/**/*.css\"",
    "lint:workload": "node workload-lab/scripts/lint.mjs",
    "validate:workload": "node workload-lab/scripts/validate-profiles.mjs",
    "test:workload": "node --test workload-lab/test/*.test.mjs",
    "test:e2e": "playwright test --workers=1",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "test:e2e:debug": "PWDEBUG=1 playwright test --headed --workers=1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "latest": "^0.2.0",
    "node": "^26.5.0"
  }
}
