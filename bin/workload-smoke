#!/usr/bin/env bash
set -euo pipefail

export TARGET_BASE_URL="${TARGET_BASE_URL:-http://host.docker.internal:3001}"
export PROFILE_PATH="${PROFILE_PATH:-/workload-lab/profiles/baseline-smoke.json}"
export WORKLOAD_SEED="${WORKLOAD_SEED:-018f3d5f-9f50-77b4-9f2a-4eec5b3f7d1a}"
export RESOURCE_ENVELOPE="${RESOURCE_ENVELOPE:-local-small}"
export APP_COMMIT="${APP_COMMIT:-$(git rev-parse HEAD)}"

local_profile_path="${PROFILE_PATH}"
if [[ "$local_profile_path" == /workload-lab/* ]]; then
  local_profile_path=".${local_profile_path}"
fi

bin/workload-validate-profile "$local_profile_path"
docker compose -f compose.workload.yml run --rm k6
