#!/usr/bin/env bash
set -euo pipefail

history_file="docs/rails-generator-history.md"

if [[ ! -f monolith/bin/rails ]]; then
  echo "Refusing to run rails generate because monolith/bin/rails does not exist yet." >&2
  exit 1
fi

quote_command() {
  printf "%q" "$1"
  shift

  for arg in "$@"; do
    printf " %q" "$arg"
  done
}

record_command() {
  local command
  command="$(quote_command bin/rails-generate "$@")"

  if grep -q "No Rails generator commands have been recorded yet." "$history_file"; then
    sed -i.bak '/No Rails generator commands have been recorded yet\./d' "$history_file"
    rm -f "${history_file}.bak"
  fi

  {
    printf "\n### %s\n\n" "$(date +%F)"
    printf -- '- Rails `8.1.3`; Ruby image `ruby:4.0.5-slim`; command: `%s`%s' "$command" $'\n'
  } >> "$history_file"
}

docker compose -f compose.generator.yml run --rm \
  --workdir /workspace/monolith \
  -e BUNDLE_GEMFILE=/workspace/monolith/Gemfile \
  generator bash -lc 'bundle install && bin/rails generate "$@"' -- "$@"
record_command "$@"
